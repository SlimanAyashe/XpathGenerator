{
  "manifest_version": 3,
  "name": "XPath Generator",
  "version": "2.0",
  "description": "AI-powered XPath generator: natural language or click-to-pick, with live highlighting",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "XPath Generator (Alt+Shift+X)"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+X",
        "mac": "Alt+Shift+X"
      },
      "description": "Open XPath Generator panel"
    }
  }
}
